# Bring your own key — any ONE of these is enough for LLM narration.
# (Without any key, agent-narrator still works via --no-llm template lines.)

# OpenAI: enables gpt-4o-mini narration AND the nicer online TTS voice.
OPENAI_API_KEY=

# Any OpenAI-compatible endpoint (e.g. OpenRouter) for narration text:
#OPENAI_BASE_URL=https://openrouter.ai/api/v1
#OPENROUTER_API_KEY=
#OPENAI_MODEL=openai/gpt-4o-mini

# Google Gemini for narration text:
GEMINI_API_KEY=
#GEMINI_MODEL=gemini-2.0-flash

# Optional overrides:
#OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Voice: the default is the FREE Microsoft Edge neural voice (no key needed).
# Pick another with `edge-tts --list-voices`:
#EDGE_TTS_VOICE=en-US-AriaNeural
